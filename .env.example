# Backend server
PORT=3001
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# Frontend
NEXT_PUBLIC_SENTRY_DSN=

# Polygon RPC (optional — falls back to publicnode)
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com/

# Polymarket Builder API credentials
NEXT_PUBLIC_POLY_BUILDER_KEY=your_builder_key
NEXT_PUBLIC_POLY_BUILDER_SECRET=your_builder_secret
NEXT_PUBLIC_POLY_BUILDER_PASSPHRASE=your_builder_passphrase
